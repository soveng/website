---
import Base from '@/layouts/Base.astro';
import { getAlumniProfileViewModel, getSovEngAlumni, getSovEngAlumniStats } from '@/lib/sovengAlumni';
import '@/styles/projects.css';

const alumni = getSovEngAlumni().map(getAlumniProfileViewModel);
const stats = getSovEngAlumniStats();
const sourceMembershipHref = alumni[0]?.sourceHref;
---

<Base
  title="SovEng Alumni"
  meta_title="SovEng Alumni"
  description="Brave souls who participated in one of the SECs working towards builindg a better internet and advancing FreedomTech"
  image="/images/project-highlights/nostr-wireframe.png"
  showCallToAction={true}
>
  <div class="alumni-page">
    <section class="alumni-hero bg-black pt-16 pb-4 text-white sm:pt-20 sm:pb-6" aria-labelledby="alumni-title">
      <div class="container max-w-[1120px]">
        <div class="alumni-hero-grid">
          <div>
            <p class="projects-eyebrow">Social Graph</p>
            <h1 id="alumni-title" class="projects-display projects-headline mt-4 text-5xl leading-none text-white sm:text-7xl lg:text-8xl">
              SovEng Alumni
            </h1>
            <p class="projects-body alumni-hero-lede mt-6 max-w-3xl text-lg leading-relaxed text-gray-300 sm:text-xl">
              Brave souls who participated in one of the SECs working towards builindg a better internet and advancing FreedomTech
            </p>
            {sourceMembershipHref && (
              <a class="alumni-source-link projects-link project-external-link--with-label mt-6" href={sourceMembershipHref} target="_blank" rel="noopener noreferrer">
                <span class="project-external-link__text">Nostr follow-list</span>
                <span aria-hidden="true">↗</span>
              </a>
            )}
          </div>

          <div class="alumni-total-count" aria-label={`${stats.total} SovEng alumni`}>
            {stats.total}
          </div>
        </div>
      </div>
    </section>

    <section id="alumni-directory" class="alumni-directory bg-black pt-0 pb-16 text-white sm:pb-20" aria-label="Sovereign Engineering alumni profiles">
      <div class="container max-w-[1120px]">
        <div class="alumni-grid" aria-label="Sovereign Engineering alumni profiles">
          {
            alumni.map((profile, index) => (
              <article class="alumni-card">
                <div class="alumni-card-top">
                  <a class="alumni-avatar-link" href={profile.profileHref} target="_blank" rel="noopener noreferrer" aria-label={`Open ${profile.displayName} on Nostr`}>
                    <span class="alumni-avatar" aria-hidden="true">
                      {profile.picture && (
                        <img
                          class="alumni-avatar-image"
                          src={profile.picture}
                          alt=""
                          width="64"
                          height="64"
                          loading={index < 6 ? 'eager' : 'lazy'}
                          decoding="async"
                          fetchpriority={index < 3 ? 'high' : 'auto'}
                          referrerpolicy="no-referrer"
                          data-alumni-avatar-image
                        />
                      )}
                      <span class="alumni-avatar-fallback">{profile.initials}</span>
                    </span>
                  </a>

                  <div class="alumni-card-identity">
                    <h3 class="projects-display alumni-card-title">
                      <a href={profile.profileHref} target="_blank" rel="noopener noreferrer">
                        {profile.displayName}
                        <span aria-hidden="true">↗</span>
                      </a>
                    </h3>
                    <button type="button" class="alumni-npub-copy" data-alumni-copy data-npub={profile.npub} aria-label={`Copy npub for ${profile.displayName}`} title="Copy npub">
                      <span class="alumni-npub">{profile.npub}</span>
                      <span class="alumni-copy-icon" aria-hidden="true"></span>
                    </button>
                  </div>
                </div>

                {profile.about ? <p class="projects-body alumni-about">{profile.about}</p> : <p class="projects-body alumni-about alumni-about--empty">No public bio.</p>}
              </article>
            ))
          }
        </div>
      </div>
    </section>

  </div>
</Base>

<script is:inline>
  (() => {
    document.querySelectorAll('[data-alumni-avatar-image]').forEach((avatarImage) => {
      if (!(avatarImage instanceof HTMLImageElement)) return;
      avatarImage.addEventListener('error', () => avatarImage.remove(), { once: true });
    });

    document.querySelectorAll('[data-alumni-copy]').forEach((trigger) => {
      if (!(trigger instanceof HTMLButtonElement)) return;
      const icon = trigger.querySelector('.alumni-copy-icon');
      const defaultLabel = trigger.getAttribute('aria-label') || 'Copy npub';
      trigger.addEventListener('click', async () => {
        const value = trigger.dataset.npub?.trim();
        if (!value) return;
        try {
          await navigator.clipboard.writeText(value);
          trigger.classList.add('is-copied');
          trigger.setAttribute('aria-label', 'Copied npub');
          if (icon) icon.textContent = '✓';
        } catch {
          trigger.classList.add('is-copy-failed');
          trigger.setAttribute('aria-label', 'Copy failed');
          if (icon) icon.textContent = '!';
        }
        window.setTimeout(() => {
          trigger.classList.remove('is-copied', 'is-copy-failed');
          trigger.setAttribute('aria-label', defaultLabel);
          if (icon) icon.textContent = '';
        }, 1400);
      });
    });
  })();
</script>

<style>
  .alumni-page {
    background: #000;
    color: #fff;
  }

  .alumni-hero {
    min-height: 0;
    position: relative;
  }

  .alumni-hero::before {
    background:
      radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--color-primary) 22%, transparent), transparent 28rem),
      linear-gradient(135deg, rgb(255 255 255 / 6%) 0 1px, transparent 1px 100%);
    background-size:
      auto,
      34px 34px;
    content: '';
    inset: 0;
    opacity: 0.34;
    pointer-events: none;
    position: absolute;
  }

  .alumni-hero > .container {
    position: relative;
    z-index: 1;
  }

  .alumni-hero-grid {
    align-items: end;
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 900px) {
    .alumni-hero-grid {
      grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    }
  }

  .alumni-hero-lede {
    text-wrap: balance;
  }

  .alumni-source-link,
  .alumni-card a,
  .alumni-card button {
    transition:
      border-color 150ms ease,
      color 150ms ease,
      opacity 150ms ease,
      transform 150ms ease;
  }

  .alumni-source-link {
    color: var(--color-primary);
    display: inline-flex;
    margin-top: 1.5rem;
    text-decoration: none;
    text-underline-offset: 0.2em;
  }

  .alumni-source-link:hover {
    color: #fff;
    text-decoration: underline;
  }

  .alumni-total-count {
    color: var(--color-primary);
    font-family: var(--font-secondary);
    font-size: clamp(5rem, 18vw, 12rem);
    line-height: 0.78;
    text-align: left;
  }

  @media (min-width: 900px) {
    .alumni-total-count {
      text-align: right;
    }
  }

  .alumni-directory {
    position: relative;
  }

  .alumni-grid {
    background: transparent;
    display: grid;
    gap: 0;
    grid-template-columns: minmax(0, 1fr);
    overflow: hidden;
  }

  @media (min-width: 720px) {
    .alumni-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1040px) {
    .alumni-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .alumni-card {
    --sep-bottom: 1px;
    --sep-right: 0px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 4%), transparent 38%),
      #030303;
    contain: layout paint;
    isolation: isolate;
    min-height: 16.5rem;
    overflow: hidden;
    padding: 1rem;
    position: relative;
    transition: background-color 150ms ease;
  }

  .alumni-card:last-child {
    --sep-bottom: 0px;
  }

  @media (min-width: 720px) {
    .alumni-card {
      --sep-bottom: 1px;
      --sep-right: 1px;
    }

    .alumni-card:nth-child(2n) {
      --sep-right: 0px;
    }

    .alumni-card:nth-last-child(-n + 2) {
      --sep-bottom: 0px;
    }
  }

  @media (min-width: 1040px) {
    .alumni-card:nth-child(2n) {
      --sep-right: 1px;
    }

    .alumni-card:nth-child(3n) {
      --sep-right: 0px;
    }

    .alumni-card:nth-last-child(-n + 3) {
      --sep-bottom: 0px;
    }
  }

  .alumni-card::before {
    background:
      radial-gradient(circle at 13% 18%, color-mix(in srgb, var(--color-primary) 42%, transparent) 0 0.35px, transparent 0.95px),
      radial-gradient(circle at 31% 72%, color-mix(in srgb, var(--color-primary) 30%, transparent) 0 0.55px, transparent 1.15px),
      radial-gradient(circle at 54% 34%, color-mix(in srgb, var(--color-primary) 24%, transparent) 0 0.28px, transparent 0.85px),
      radial-gradient(circle at 72% 66%, color-mix(in srgb, var(--color-primary) 36%, transparent) 0 0.85px, transparent 1.45px),
      radial-gradient(circle at 87% 24%, color-mix(in srgb, var(--color-primary) 28%, transparent) 0 0.42px, transparent 1px),
      radial-gradient(circle at 18% 88%, color-mix(in srgb, var(--color-primary) 22%, transparent) 0 0.62px, transparent 1.25px),
      radial-gradient(circle at 43% 51%, color-mix(in srgb, var(--color-primary) 20%, transparent) 0 0.22px, transparent 0.8px),
      radial-gradient(circle at 94% 82%, color-mix(in srgb, var(--color-primary) 32%, transparent) 0 0.72px, transparent 1.35px),
      radial-gradient(ellipse at 48% 42%, color-mix(in srgb, var(--color-primary) 7%, transparent), transparent 64%),
      linear-gradient(color-mix(in srgb, var(--color-primary) 5%, transparent), color-mix(in srgb, var(--color-primary) 5%, transparent));
    content: '';
    inset: 0;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    transition: opacity 150ms ease;
    z-index: 0;
  }

  .alumni-card::after {
    background:
      linear-gradient(to bottom, transparent, rgb(255 255 255 / 11%) 18%, rgb(255 255 255 / 7%) 72%, transparent) right top / var(--sep-right) 100% no-repeat,
      linear-gradient(to right, transparent, rgb(255 255 255 / 11%) 18%, rgb(255 255 255 / 7%) 72%, transparent) left bottom / 100% var(--sep-bottom) no-repeat;
    content: '';
    inset: 0;
    pointer-events: none;
    position: absolute;
    z-index: 0;
  }

  .alumni-card > * {
    position: relative;
    z-index: 1;
  }

  .alumni-card:hover {
    background-color: #070202;
  }

  .alumni-card:hover::before,
  .alumni-card:focus-within::before {
    opacity: 1;
  }

  .alumni-card-top {
    align-items: center;
    display: flex;
    gap: 0.85rem;
  }

  .alumni-avatar-link {
    color: inherit;
    display: inline-flex;
    flex: 0 0 auto;
    text-decoration: none;
  }

  .alumni-avatar {
    align-items: center;
    background: #111;
    border: 1px solid rgb(255 255 255 / 12%);
    color: var(--color-primary);
    display: inline-flex;
    font-family: var(--font-secondary);
    font-size: 1.45rem;
    height: 4rem;
    justify-content: center;
    overflow: hidden;
    position: relative;
    width: 4rem;
  }

  .alumni-avatar-image {
    display: block;
    height: 100%;
    inset: 0;
    object-fit: cover;
    position: absolute;
    width: 100%;
    z-index: 1;
  }

  .alumni-avatar-fallback {
    transform: translateY(0.05em);
  }

  .alumni-avatar-link:hover .alumni-avatar,
  .alumni-avatar-link:focus-visible .alumni-avatar {
    border-color: var(--color-primary);
  }

  .alumni-card-identity {
    min-width: 0;
  }

  .alumni-card-title {
    font-size: 1.45rem;
    line-height: 1.05;
    margin: 0;
    text-transform: none;
  }

  .alumni-card-title a {
    color: #fff;
    display: inline-flex;
    gap: 0.35rem;
    text-decoration: none;
  }

  .alumni-card-title a:hover,
  .alumni-card-title a:focus-visible {
    color: var(--color-primary);
  }

  .alumni-npub-copy {
    align-items: flex-start;
    background: transparent;
    border: 0;
    color: rgb(255 255 255 / 42%);
    cursor: pointer;
    display: inline-flex;
    font-family: var(--font-primary);
    font-size: 0.74rem;
    gap: 0.45rem;
    letter-spacing: 0.03em;
    margin: 0.35rem 0 0;
    max-width: 100%;
    min-width: 0;
    padding: 0;
    text-align: left;
  }

  .alumni-npub-copy:hover,
  .alumni-npub-copy:focus-visible,
  .alumni-npub-copy.is-copied {
    color: var(--color-primary);
  }

  .alumni-npub-copy.is-copy-failed {
    color: #fff;
  }

  .alumni-npub {
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .alumni-copy-icon {
    background: currentColor;
    display: inline-flex;
    flex: 0 0 auto;
    height: 0.95rem;
    line-height: 1;
    mask: url('/images/copy-to-clipboard.svg') center / contain no-repeat;
    width: 0.95rem;
    margin-top: 0.05rem;
  }

  .alumni-npub-copy.is-copied .alumni-copy-icon,
  .alumni-npub-copy.is-copy-failed .alumni-copy-icon {
    align-items: center;
    background: transparent;
    font-size: 0.9rem;
    font-weight: 700;
    justify-content: center;
    mask: none;
  }

  .alumni-about {
    color: rgb(255 255 255 / 58%);
    display: -webkit-box;
    font-size: 0.92rem;
    line-height: 1.5;
    margin: 1rem 0 0;
    min-height: 4.15rem;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .alumni-about--empty {
    color: rgb(255 255 255 / 32%);
    font-style: italic;
  }

  .alumni-card a:focus-visible,
  .alumni-card button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }
</style>
