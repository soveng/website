---
import Base from '@/layouts/Base.astro';
import {
  getAlumniProfileViewModel,
  getSovEngAlumni,
  getSovEngAlumniStats,
  hasSourceLockedAssociationData,
} from '@/lib/sovengAlumni';
import '@/styles/projects.css';

const alumni = getSovEngAlumni().map(getAlumniProfileViewModel);
const stats = getSovEngAlumniStats();
const hasAssociations = hasSourceLockedAssociationData();
const sourceMembershipHref = alumni[0]?.sourceHref;
const lastFetchedLabel = stats.lastFetchedAt
  ? new Intl.DateTimeFormat('en', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' }).format(new Date(stats.lastFetchedAt))
  : 'source locked';
---

<Base
  title="SovEng Alumni"
  meta_title="SovEng Alumni"
  description="A source-locked roll call of Sovereign Engineering alumni, preserving raw Nostr kind 0 profile events from the public follow-list."
  image="/images/project-highlights/nostr-wireframe.png"
  showCallToAction={true}
>
  <div class="alumni-page">
    <section class="alumni-hero bg-black py-24 text-white sm:py-32" aria-labelledby="alumni-title">
      <div class="container max-w-[1120px]">
        <div class="alumni-hero-grid">
          <div>
            <p class="projects-eyebrow">SovEng social graph</p>
            <h1 id="alumni-title" class="projects-display projects-headline mt-4 text-5xl leading-none text-white sm:text-7xl lg:text-8xl">
              Alumni
            </h1>
            <p class="projects-body alumni-hero-lede mt-6 max-w-3xl text-lg leading-relaxed text-gray-300 sm:text-xl">
              A public roll call of builders from the Sovereign Engineering orbit. Profiles are sourced from the approved Nostr follow-list and keep the raw
              kind 0 events intact for deterministic review.
            </p>
          </div>

          <aside class="alumni-manifest" aria-label="Alumni manifest provenance">
            <p class="projects-eyebrow">Manifest</p>
            <p class="manifest-copy projects-body">
              No scraped biographies, no inferred SEC/project tags. Just the public follow-list plus each profile's latest source-locked kind 0 event.
            </p>
            {sourceMembershipHref && (
              <a class="projects-link project-external-link--with-label" href={sourceMembershipHref} target="_blank" rel="noopener noreferrer">
                <span class="project-external-link__text">View source list</span>
                <span aria-hidden="true">↗</span>
              </a>
            )}
          </aside>
        </div>

        <dl class="alumni-stats mt-10" aria-label="Alumni source stats">
          <div>
            <dt>Profiles</dt>
            <dd>{stats.total}</dd>
          </div>
          <div>
            <dt>With bios</dt>
            <dd>{stats.withAbout}</dd>
          </div>
          <div>
            <dt>With avatars</dt>
            <dd>{stats.withPicture}</dd>
          </div>
          <div>
            <dt>Source refresh</dt>
            <dd>{lastFetchedLabel}</dd>
          </div>
        </dl>

        <div class="alumni-source-note projects-body mt-8">
          <p>
            Source membership:
            {sourceMembershipHref ? (
              <a href={sourceMembershipHref} target="_blank" rel="noopener noreferrer">public Nostr follow-list</a>
            ) : (
              'public Nostr follow-list'
            )}.
          </p>
          {!hasAssociations && <p>SEC/project/tag chips are intentionally hidden until those associations are backed by an approved canonical source.</p>}
        </div>
      </div>
    </section>

    <section id="alumni-directory" class="alumni-directory bg-black py-16 text-white sm:py-20" aria-labelledby="alumni-directory-title">
      <div class="container max-w-[1120px]">
        <figure class="alumni-separator" aria-hidden="true">
          <img src="/images/contest/separator-ship.png" alt="" width="2172" height="724" loading="lazy" decoding="async" />
        </figure>

        <div class="alumni-directory-header">
          <div>
            <p class="projects-eyebrow">Roll call</p>
            <h2 id="alumni-directory-title" class="projects-display projects-headline mt-3 text-4xl text-white sm:text-5xl">Builders in the wild</h2>
          </div>
          <p class="projects-body alumni-directory-copy">
            Open a Nostr profile, copy the npub, or pop the QR dialog. Cards are intentionally sparse: names, avatars, bios, and NIP-05 handles come only from
            kind 0 metadata.
          </p>
        </div>

        <div class="alumni-grid" aria-label="Sovereign Engineering alumni profiles">
          {
            alumni.map((profile) => (
              <article class="alumni-card">
                <div class="alumni-card-top">
                  <a class="alumni-avatar-link" href={profile.profileHref} target="_blank" rel="noopener noreferrer" aria-label={`Open ${profile.displayName} on Nostr`}>
                    <span class="alumni-avatar" aria-hidden="true">
                      {profile.picture && <img class="alumni-avatar-image" src={profile.picture} alt="" loading="lazy" decoding="async" referrerpolicy="no-referrer" data-alumni-avatar-image />}
                      <span class="alumni-avatar-fallback">{profile.initials}</span>
                    </span>
                  </a>

                  <button
                    type="button"
                    class="alumni-qr-button"
                    data-alumni-qr
                    data-profile-name={profile.displayName}
                    data-profile-href={profile.profileHref}
                    data-npub={profile.npub}
                    data-qr-src={profile.qrImageHref}
                    aria-label={`Show QR code for ${profile.displayName}`}
                  >
                    QR
                  </button>
                </div>

                <h3 class="projects-display alumni-card-title">
                  <a href={profile.profileHref} target="_blank" rel="noopener noreferrer">
                    {profile.displayName}
                    <span aria-hidden="true">↗</span>
                  </a>
                </h3>
                <p class="alumni-handle">{profile.handle}</p>
                {profile.about ? <p class="projects-body alumni-about">{profile.about}</p> : <p class="projects-body alumni-about alumni-about--empty">No public bio in kind 0.</p>}

                <footer class="alumni-card-foot">
                  <time datetime={profile.updatedAt}>kind 0 · {profile.updatedLabel}</time>
                  <a href={profile.profileHref} target="_blank" rel="noopener noreferrer" aria-label={`Open ${profile.displayName} Nostr profile`}>
                    Profile
                  </a>
                </footer>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <dialog id="alumni-qr-dialog" class="alumni-qr-dialog" aria-labelledby="alumni-qr-title">
      <form method="dialog" class="alumni-qr-panel">
        <button type="submit" class="alumni-dialog-close" aria-label="Close QR dialog">×</button>
        <p class="projects-eyebrow">Nostr profile</p>
        <h2 id="alumni-qr-title" class="projects-display projects-headline">Profile QR</h2>
        <img class="alumni-qr-image" alt="" width="240" height="240" loading="lazy" decoding="async" referrerpolicy="no-referrer" />
        <p class="alumni-dialog-npub projects-body"></p>
        <div class="alumni-dialog-actions">
          <button type="button" class="alumni-dialog-copy">Copy npub</button>
          <a class="btn-retro alumni-dialog-link" href="#" target="_blank" rel="noopener noreferrer">Open on Nostr</a>
        </div>
      </form>
    </dialog>
  </div>
</Base>

<script is:inline>
  (() => {
    const dialog = document.getElementById('alumni-qr-dialog');
    if (!(dialog instanceof HTMLDialogElement)) return;

    const title = dialog.querySelector('#alumni-qr-title');
    const image = dialog.querySelector('.alumni-qr-image');
    const npub = dialog.querySelector('.alumni-dialog-npub');
    const link = dialog.querySelector('.alumni-dialog-link');
    const copy = dialog.querySelector('.alumni-dialog-copy');
    let activeTrigger = null;

    document.querySelectorAll('[data-alumni-avatar-image]').forEach((avatarImage) => {
      if (!(avatarImage instanceof HTMLImageElement)) return;
      avatarImage.addEventListener('error', () => avatarImage.remove(), { once: true });
    });

    document.querySelectorAll('[data-alumni-qr]').forEach((trigger) => {
      if (!(trigger instanceof HTMLElement)) return;
      trigger.addEventListener('click', () => {
        const name = trigger.dataset.profileName || 'Nostr profile';
        const qrSrc = trigger.dataset.qrSrc;
        const profileHref = trigger.dataset.profileHref || '#';
        const profileNpub = trigger.dataset.npub || '';
        activeTrigger = trigger;

        if (title) title.textContent = name;
        if (image instanceof HTMLImageElement && qrSrc) {
          image.src = qrSrc;
          image.alt = `QR code for ${name}`;
        }
        if (npub) npub.textContent = profileNpub;
        if (link instanceof HTMLAnchorElement) link.href = profileHref;
        if (copy instanceof HTMLButtonElement) copy.textContent = 'Copy npub';

        if (!dialog.open) dialog.showModal();
      });
    });

    if (copy instanceof HTMLButtonElement) {
      copy.addEventListener('click', async () => {
        const value = npub?.textContent?.trim();
        if (!value) return;
        try {
          await navigator.clipboard.writeText(value);
          copy.textContent = 'Copied';
        } catch {
          copy.textContent = 'Select npub';
        }
        window.setTimeout(() => {
          if (dialog.open) copy.textContent = 'Copy npub';
        }, 1600);
      });
    }

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });

    dialog.addEventListener('keydown', (event) => {
      if (event.key !== 'Tab') return;
      const focusable = [...dialog.querySelectorAll('button, a[href]')].filter((element) => element instanceof HTMLElement && !element.hasAttribute('disabled'));
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (!first || !last) return;
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });

    dialog.addEventListener('close', () => {
      if (activeTrigger instanceof HTMLElement) activeTrigger.focus();
    });
  })();
</script>

<style>
  .alumni-page {
    background: #000;
    color: #fff;
  }

  .alumni-hero {
    min-height: 74vh;
    position: relative;
  }

  .alumni-hero::before {
    background:
      radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--color-primary) 22%, transparent), transparent 28rem),
      linear-gradient(135deg, rgb(255 255 255 / 6%) 0 1px, transparent 1px 100%);
    background-size:
      auto,
      34px 34px;
    content: '';
    inset: 0;
    opacity: 0.34;
    pointer-events: none;
    position: absolute;
  }

  .alumni-hero > .container {
    position: relative;
    z-index: 1;
  }

  .alumni-hero-grid {
    align-items: end;
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 900px) {
    .alumni-hero-grid {
      grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    }
  }

  .alumni-hero-lede,
  .alumni-directory-copy {
    text-wrap: balance;
  }

  .alumni-manifest {
    border-left: 1px solid rgb(255 255 255 / 16%);
    padding-left: 1.25rem;
  }

  .manifest-copy {
    color: rgb(255 255 255 / 62%);
    line-height: 1.55;
    margin: 1rem 0 1.2rem;
  }

  .alumni-stats {
    background: rgb(255 255 255 / 10%);
    border: 1px solid rgb(255 255 255 / 10%);
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-width: 860px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .alumni-stats {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .alumni-stats div {
    background: #030303;
    padding: 1rem;
  }

  .alumni-stats dt {
    color: rgb(255 255 255 / 45%);
    font-family: var(--font-primary);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .alumni-stats dd {
    color: var(--color-primary);
    font-family: var(--font-secondary);
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1;
    margin: 0.45rem 0 0;
  }

  .alumni-source-note {
    color: rgb(255 255 255 / 58%);
    display: grid;
    gap: 0.35rem;
    max-width: 860px;
  }

  .alumni-source-note p {
    margin: 0;
  }

  .alumni-source-note a,
  .alumni-card a,
  .alumni-card button {
    transition:
      border-color 150ms ease,
      color 150ms ease,
      opacity 150ms ease,
      transform 150ms ease;
  }

  .alumni-source-note a {
    color: var(--color-primary);
    text-decoration: none;
    text-underline-offset: 0.2em;
  }

  .alumni-source-note a:hover {
    color: #fff;
    text-decoration: underline;
  }

  .alumni-directory {
    position: relative;
  }

  .alumni-separator {
    margin: -2rem auto 2.5rem;
    max-width: min(760px, 100%);
    opacity: 0.64;
  }

  .alumni-separator img {
    display: block;
    height: auto;
    width: 100%;
  }

  .alumni-directory-header {
    align-items: end;
    display: grid;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 900px) {
    .alumni-directory-header {
      grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.7fr);
    }
  }

  .alumni-directory-copy {
    color: rgb(255 255 255 / 58%);
    line-height: 1.55;
    margin: 0;
  }

  .alumni-grid {
    background: rgb(255 255 255 / 10%);
    border: 1px solid rgb(255 255 255 / 10%);
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    overflow: hidden;
  }

  .alumni-card {
    background:
      linear-gradient(180deg, rgb(255 255 255 / 4%), transparent 38%),
      #030303;
    min-height: 19rem;
    padding: 1rem;
  }

  .alumni-card:hover {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-primary) 9%, transparent), transparent 42%),
      #050505;
  }

  .alumni-card-top,
  .alumni-card-foot {
    align-items: center;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
  }

  .alumni-avatar-link {
    color: inherit;
    display: inline-flex;
    text-decoration: none;
  }

  .alumni-avatar {
    align-items: center;
    background: #111;
    border: 1px solid rgb(255 255 255 / 12%);
    color: var(--color-primary);
    display: inline-flex;
    font-family: var(--font-secondary);
    font-size: 1.45rem;
    height: 4rem;
    justify-content: center;
    overflow: hidden;
    position: relative;
    width: 4rem;
  }

  .alumni-avatar-image {
    display: block;
    height: 100%;
    inset: 0;
    object-fit: cover;
    position: absolute;
    width: 100%;
    z-index: 1;
  }

  .alumni-avatar-fallback {
    transform: translateY(0.05em);
  }

  .alumni-avatar-link:hover .alumni-avatar,
  .alumni-avatar-link:focus-visible .alumni-avatar {
    border-color: var(--color-primary);
  }

  .alumni-qr-button {
    align-items: center;
    background: transparent;
    border: 1px solid rgb(255 255 255 / 14%);
    color: rgb(255 255 255 / 48%);
    cursor: pointer;
    display: inline-flex;
    font-family: var(--font-primary);
    font-size: 0.68rem;
    justify-content: center;
    letter-spacing: 0.16em;
    min-height: 2.75rem;
    min-width: 2.75rem;
    padding: 0.45rem 0.55rem;
    text-transform: uppercase;
  }

  .alumni-qr-button:hover,
  .alumni-qr-button:focus-visible {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .alumni-card-title {
    font-size: 1.45rem;
    line-height: 1.05;
    margin: 1.1rem 0 0;
    text-transform: none;
  }

  .alumni-card-title a {
    color: #fff;
    display: inline-flex;
    gap: 0.35rem;
    text-decoration: none;
  }

  .alumni-card-title a:hover,
  .alumni-card-title a:focus-visible {
    color: var(--color-primary);
  }

  .alumni-handle {
    color: rgb(255 255 255 / 42%);
    font-family: var(--font-primary);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    margin: 0.45rem 0 0;
    overflow-wrap: anywhere;
  }

  .alumni-about {
    color: rgb(255 255 255 / 58%);
    display: -webkit-box;
    font-size: 0.92rem;
    line-height: 1.5;
    margin: 1rem 0 0;
    min-height: 4.15rem;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .alumni-about--empty {
    color: rgb(255 255 255 / 32%);
    font-style: italic;
  }

  .alumni-card-foot {
    border-top: 1px solid rgb(255 255 255 / 8%);
    color: rgb(255 255 255 / 34%);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    margin-top: 1rem;
    padding-top: 0.85rem;
    text-transform: uppercase;
  }

  .alumni-card-foot a {
    color: rgb(255 255 255 / 50%);
    text-decoration: none;
  }

  .alumni-card-foot a:hover,
  .alumni-card-foot a:focus-visible {
    color: var(--color-primary);
  }

  .alumni-card a:focus-visible,
  .alumni-card button:focus-visible,
  .alumni-dialog-close:focus-visible,
  .alumni-dialog-copy:focus-visible,
  .alumni-dialog-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .alumni-qr-dialog {
    background: transparent;
    border: 0;
    color: #fff;
    inset: 0;
    margin: auto;
    max-width: min(92vw, 420px);
    padding: 0;
    position: fixed;
    width: min(92vw, 420px);
  }

  .alumni-qr-dialog::backdrop {
    background: rgb(0 0 0 / 78%);
    backdrop-filter: blur(8px);
  }

  .alumni-qr-panel {
    background:
      linear-gradient(180deg, rgb(255 255 255 / 8%), transparent 32%),
      #050505;
    border: 1px solid rgb(255 255 255 / 16%);
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    position: relative;
    text-align: center;
  }

  .alumni-qr-panel h2 {
    font-size: 2rem;
    line-height: 1;
    margin: 0;
    text-transform: none;
  }

  .alumni-dialog-close {
    align-items: center;
    background: transparent;
    border: 0;
    color: rgb(255 255 255 / 54%);
    cursor: pointer;
    display: inline-flex;
    font-size: 2rem;
    height: 2.75rem;
    justify-content: center;
    line-height: 1;
    position: absolute;
    right: 0.45rem;
    top: 0.35rem;
    width: 2.75rem;
  }

  .alumni-dialog-close:hover {
    color: var(--color-primary);
  }

  .alumni-qr-image {
    background: #fff;
    border: 8px solid #fff;
    height: 240px;
    justify-self: center;
    width: 240px;
  }

  .alumni-dialog-npub {
    color: rgb(255 255 255 / 62%);
    font-size: 0.86rem;
    margin: 0;
    overflow-wrap: anywhere;
  }

  .alumni-dialog-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .alumni-dialog-copy {
    background: transparent;
    border: 1px solid rgb(255 255 255 / 18%);
    color: rgb(255 255 255 / 68%);
    cursor: pointer;
    font-family: var(--font-primary);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    min-height: 2.75rem;
    padding: 0.7rem 0.9rem;
    text-transform: uppercase;
  }

  .alumni-dialog-copy:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .alumni-dialog-link {
    justify-self: center;
  }
</style>
