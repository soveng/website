---
import projectHighlights from '@/data/projectHighlights';
import Base from '@/layouts/Base.astro';
import ProjectArchiveGrid from '@/layouts/components/ProjectArchiveGrid.astro';
import ProjectFeatureGrid from '@/layouts/components/ProjectFeatureGrid.astro';
import ProjectsHero from '@/layouts/components/ProjectsHero.astro';
import ProjectsSectionHeader from '@/layouts/components/ProjectsSectionHeader.astro';
import { getCohortSummaries } from '@/lib/showcase';
import '@/styles/projects.css';

const cohortSummaries = getCohortSummaries({ order: 'desc' });
const originSummaries = cohortSummaries.filter((summary) => summary.cohort === 'SEC-00');
const numberedCohorts = cohortSummaries.filter((summary) => summary.cohort !== 'SEC-00');
const recentSummaries = numberedCohorts.slice(0, 3);
const earlierSummaries = numberedCohorts.slice(3);
---

<Base
  title="Demo Day Projects"
  meta_title="Demo Day Projects"
  description="Explore the projects Sovereign Engineering brought into the world, from Blossom and Nutzaps to Nsite, Wikifreedia, TollGate, Zapstore, and more."
  image="/images/project-highlights/nostr-wireframe.png"
  showCallToAction={true}
>
  <div class="projects-page">
    <ProjectsHero />

    <section id="project-highlights" class="bg-black py-8 text-white sm:py-10">
      <div class="container max-w-[1120px]">
        <h2 class="projects-display projects-headline mb-10 text-4xl text-white">Highlights</h2>

        <ProjectFeatureGrid highlights={projectHighlights} />
      </div>
    </section>

    <section id="project-archives" class="bg-black py-16 text-white sm:py-20">
      <div class="container max-w-[1120px]">
        <ProjectsSectionHeader
          eyebrow="Cohort archives"
          title="Friday = Demo Day"
          description="Each cohort page is the running record of what participants showed across that cohort: the apps, protocols, and tools that actually shipped. Recent cohorts are up top; work backward through the earlier archives, or open Origin for where it began."
        />

        <ProjectArchiveGrid
          upcoming={{
            cohort: 'SEC-08',
            subtitle: 'YOLO++',
            preview: 'Six weeks starting July 20',
            meta: 'Your project?',
            href: '/#apply',
          }}
          recentSummaries={recentSummaries}
          earlierSummaries={earlierSummaries}
          originSummaries={originSummaries}
        />

        <figure class="projects-separator" aria-hidden="true">
          <img
            src="/images/contest/separator-ship.png"
            alt=""
            width="2172"
            height="724"
            loading="lazy"
            decoding="async"
          />
        </figure>

        <div class="projects-podcast-cta">
          <p class="projects-eyebrow">No Solutions</p>
          <h2 class="projects-display projects-headline mt-3 text-4xl text-white">Only Trade-Offs</h2>
          <p class="projects-body mt-3 max-w-2xl text-lg leading-relaxed text-gray-300">
            Sovereign Engineering is dialogical development. We talk, we walk, we ship on Fridays. The cohort pages above
            are the outcome of our Demo Days. No Solutions is the podcast from the same program: builders, protocols, trade-offs, and the
            arguments that produced the work in these archives.
          </p>
          <a href="/podcast" class="btn-retro mt-6 inline-block">Listen to No Solutions</a>
        </div>
      </div>
    </section>
  </div>
</Base>
