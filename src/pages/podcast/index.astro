---
import Base from "@/layouts/Base.astro";
import BigBlockQuote from "@/layouts/components/BigBlockQuote.astro";
import DynamicIcon from "@/helpers/DynamicIcon";
import { getEpisodes } from "@/lib/podcast";

const metaParagraph =
  `Across a dozen walking dialogues the <strong>No Solutions</strong> crew keeps circling the same north star: ` +
  `<strong>freedom is an engineering practice</strong>. Start ugly, ship weekly, and invite the world's critique. ` +
  `Momentum replaces perfection, open protocols replace gate-keepers, and conversations on the trail turn wild ideas into code that empowers the individual.`;

const metaQuote = `Start ugly, iterate publicly, and keep walking—this is Sovereign Engineering in motion.`;

const pageTitle = "No Solutions";
const metaTitle = "No Solutions — A Sovereign Engineering Podcast";
const byline = `Walking towards a better internet since \
  <a href="https://mempool.space/block/882690"\
    target="_blank"\
    rel="noopener noreferrer"\
  >882,690</a>.`;
const pageDescription = "Walking dialogues about freedom, code, and sovereign engineering. Listen to the No Solutions podcast by Sovereign Engineering.";

const episodes = await getEpisodes();
---

<Base title={pageTitle} meta_title={metaTitle} description={pageDescription} image="/images/nosolutions-og.jpg">
  <!-- Hero Section -->
  <section class="section-sm bg-black text-white pt-[8rem]">
    <div class="container">
      <!-- Header -->
      <div class="row justify-center">
        <div class="col-12 text-center">
          <a href="https://podcastindex.org/podcast/7206062" target="_blank" rel="noopener noreferrer">
            <img src="/images/nosolutions-cover.jpg" alt="No Solutions Podcast Cover" class="mx-auto mb-6 w-48 h-48 shadow-lg object-cover" />
          </a>
          <h1 class="mb-4 text-white uppercase" style="font-size: 3rem;">{pageTitle}</h1>
          <p class="text-xl font-primary uppercase tracking-wider mb-8 " set:html={byline} />
        </div>
      </div>

      <!-- Content Section -->
      <div class="row justify-center">
        <div class="max-w-[960px] mx-auto">
          <div class="content [&>p]:text-xl [&>p]:text-white mb-12">
            <p set:html={metaParagraph} />
          </div>
        </div>
      </div>

      <!-- Platform Links -->
      <div class="row justify-center">
        <div class="md:col-10 lg:col-8">
          <div class="flex flex-wrap justify-center gap-4 mb-12">
            <a
              href="https://castr.me/npub1n00yy9y3704drtpph5wszen64w287nquftkcwcjv7gnnkpk2q54s73000n"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-retro"
            >
              castr.me
            </a>
            <a
              href="https://podcastindex.org/podcast/7206062"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-retro"
            >
              Podcast Index
            </a>
            <a
              href="https://sovereignengineering.io/dialogues.xml"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-retro"
            >
              <DynamicIcon icon="FaRss" className="inline-block w-4 h-4 mr-2 align-text-bottom" />
              RSS
            </a>
            <a
              href="https://njump.to/nosolutions@sovereignengineering.io"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-retro"
            >
              <DynamicIcon icon="FaFeather" className="inline-block w-4 h-4" />
              <span class="sr-only">Nostr Profile</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Centered Quote -->
      <BigBlockQuote
        quote={metaQuote}
      />

      <!-- Episodes -->
      <div class="row justify-center">
        <div class="max-w-[960px] mx-auto w-full">
          <hr class="border-gray-700 mb-8" />
          <h2 class="text-white uppercase text-2xl mb-8 font-primary tracking-wider text-center">Episodes</h2>
          <div class="space-y-6">
            {episodes.map((ep) => (
              <article
                class="group border-2 border-t-white border-r-gray-700 border-b-gray-700 border-l-white bg-[#1a1a1a] hover:bg-[#222] transition-colors"
              >
                <a href={`/podcast/${ep.slug}`} class="no-underline hover:no-underline block">
                  <div class="flex flex-col sm:flex-row gap-4 p-4">
                    {/* Episode artwork */}
                    <div class="shrink-0">
                      <img
                        src={ep.imageUrl}
                        alt={ep.title}
                        class="w-full sm:w-32 sm:h-32 object-cover"
                        loading="lazy"
                      />
                    </div>

                    {/* Episode info */}
                    <div class="flex-1 min-w-0">
                      <h3 class="text-white text-lg font-bold font-primary uppercase leading-tight group-hover:text-primary transition-colors mb-1">
                        {ep.title}
                      </h3>

                      {/* Meta line: guest, date, duration */}
                      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-400 mb-2 font-primary">
                        {ep.guestName && (
                          <span class="inline-flex items-center gap-1.5">
                            {ep.guestImg && (
                              <img
                                src={ep.guestImg}
                                alt={ep.guestName}
                                class="w-5 h-5 rounded-full object-cover"
                                loading="lazy"
                              />
                            )}
                            <span class="text-gray-300">{ep.guestName}</span>
                            <span class="text-gray-600">({ep.guestRole})</span>
                          </span>
                        )}
                        <span>{ep.pubDate}</span>
                        <span>{ep.durationFormatted}</span>
                      </div>

                      {/* First paragraph / quote */}
                      {ep.subtitle && (
                        <p class="text-gray-400 text-sm italic line-clamp-2">
                          {ep.subtitle}
                        </p>
                      )}
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>
      </div>

      <!-- Next Link -->
      <section class="section-sm bg-black text-white">
        <div class="container">
          <p class="mt-6"><a href="/projects" class="underline decoration-2 underline-offset-2 hover:text-primary">Next: Explore the projects we discuss &rarr;</a></p>
        </div>
      </section>
    </div>
  </section>
</Base>
