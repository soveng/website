---
import Base from "@/layouts/Base.astro";

const heroImage = "/images/contest/t-shirt-design-contest.png";
const submissionFormUrl = "" as string;
const submissionFormIsExternal = submissionFormUrl.startsWith("http");
const prizes = [
  { place: "1st", tier: "first", rank: "1", suffix: "st", cue: "Winner", amount: "1,000,000", unit: "sats" },
  { place: "2nd", tier: "second", rank: "2", suffix: "nd", cue: "Runner-up", amount: "250,000", unit: "sats" },
  { place: "3rd", tier: "third", rank: "3", suffix: "rd", cue: "Third place", amount: "100,000", unit: "sats" },
];
const contestDetails = [
  { label: "Contest", value: "SEC-08 T-shirt design" },
  { label: "Final date", value: "15 June 2026" },
  { label: "Submit", value: "Post on Nostr and tag #SovEng" },
  { label: "Theme", value: "Summer, Sovereign Engineers, Bitcoin, Nostr, Pirates" },
];
const requirements = [
  "Print-friendly: bold shapes, max 4 colors, avoid spaghetti detail.",
  "Show both front and back design of the T-shirt.",
  "Keep editable source files around",
  "	Post on Nostr and tag #SovEng"
];
---

<Base
  title="SEC-08 T-Shirt Design Contest"
  meta_title="SEC-08 T-Shirt Design Contest"
  description="Submit a Sovereign Engineering SEC-08 T-shirt design by 15 June 2026 for a bounty of 1,350,000 sats."
  image={heroImage}
  showCallToAction={true}
>
  <article class="contest-page" aria-labelledby="contest-title">
    <header class="contest-container masthead">
      <p class="eyebrow">Final date · 15 June 2026</p>
      <div class="title-row">
        <h1 id="contest-title">Design Contest</h1>
      </div>
      <p class="lead"><strong><u>WANTED</u>:</strong> Legendary Designers for <strong>SEC-08</strong></p>
    </header>

    <figure class="contest-container poster" aria-label="SEC-08 T-shirt design contest poster">
      <img src={heroImage} alt="SEC-08 design contest poster" width="1672" height="941" loading="eager" decoding="async" />
    </figure>

    <section class="contest-container lower-grid" aria-label="Contest brief and details">
      <div class="contest-copy">
        <section aria-labelledby="brief-heading">
          <h2 id="brief-heading">Brief</h2>
          <p>
            Sovereign Engineering needs a legendary tee for SEC-08, and we're handing the brush to you. This is your shot to ink yourself into the lore of SEC: the way past cohorts' artwork still floats around Madeira, Bitcoin meetups, and Nostr feeds years later.
          </p>
          <p>
            The theme is Summer on the high seas of freedom tech. Think pirates with full nodes. Crabs relaying Nostr events. Seagulls shooting chasu tokens. A jolly roger crossed with a lightning bolt. Sun-bleached sails, sats in the air, a crew of sovereign engineers raiding the opensource seas.
          </p>
          <p>
            Lean into the meme for all we care, as a master once said, <a href="https://www.youtube.com/watch?v=PBAuHv5cPl8&" target="_blank" rel="noopener noreferrer">"we are memeing the future into reality"</a>. Or as the other one for he said, "if you look long enough into the meme, the meme stares back at you". We want the shirt people will fight over at BBQs, and hand them down in 2069 as heirlooms. Inside jokes welcome. Bitcoin culture, Nostr autism, pirate folklore - do your worst! The weirder, the better.
          </p>
          <p>
            If you really need more context, read <a href="https://njump.me/naddr1qq9hxetr95crsttedakx7q3qs0veng2gvfwr62acrxhnqexq76sj6ldg3a5t935jy8e6w3shr5vsxpqqqp65w0wz9k6" target="_blank" rel="noopener noreferrer">SEC-08</a> post or check past <a href="/swag">designs</a> to see what made each SEC design unique.
          </p>
          <p>
            And please don't steal stuff, the first rule at SEC is, "Don't go to jail!" - it's true.
          </p>
          <p>
            Post your designs on Nostr and tag <a href="https://nostrudel.ninja/t/soveng" target="_blank"  rel="noopener noreferrer">#SovEng</a> before <strong>15 June 2026</strong>. Total bounty worth <strong>1,350,000 sats</strong>. Drop as many designs as you want. Raid the feed! Now, grab yer brushes, crack them knuckes, get yer sea legs on, ye sovereign scallywag - an' get yer captain the rum!
          </p>
        </section>

        <section class="requirements" aria-labelledby="requirements-heading">
          <h2 id="requirements-heading">Requirements</h2>
          <ul>
            {requirements.map((requirement) => <li>{requirement}</li>)}
          </ul>
        </section>
      </div>

      <aside class="details" aria-labelledby="details-heading">
        <h2 id="details-heading">Details</h2>
        <table>
          <tbody>
            {contestDetails.map((detail) => (
              <tr>
                <th scope="row">{detail.label}</th>
                <td>{detail.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </aside>
    </section>

    <section class="contest-container prize-marquee" aria-label="Contest prizes">
      <div class="total">
        <span>Total bounty</span>
        <strong>
          <span class="total-amount">1,350,000</span>
          <span class="total-unit">sats</span>
        </strong>
      </div>
      {prizes.map((prize) => (
        <div class={`marquee-prize ${prize.tier}`}>
          <div class="rank" aria-label={prize.place}>
            <span class="rank-number">{prize.rank}</span>
            <span class="rank-suffix">{prize.suffix}</span>
          </div>
          <span class="rank-cue">{prize.cue}</span>
          <strong>
            <span class="prize-amount">{prize.amount}</span>
            <span class="prize-unit">{prize.unit}</span>
          </strong>
        </div>
      ))}
    </section>
  </article>
</Base>

<style>
  .contest-page {
    background: var(--color-body);
    color: var(--color-text);
    min-height: 100vh;
    padding: 8rem 0 6rem;
  }

  .contest-container {
    margin-inline: auto;
    width: min(1180px, calc(100% - 2rem));
  }

  .masthead {
    padding: 4.5rem 0 1.5rem;
  }

  .title-row {
    align-items: center;
    display: flex;
    gap: 1.5rem;
    justify-content: space-between;
  }

  .eyebrow,
  table th {
    color: var(--color-primary);
    font-family: var(--font-secondary);
    letter-spacing: 0.14em;
    margin: 0 0 0.9rem;
    text-transform: uppercase;
  }

  h1,
  h2 {
    color: var(--color-text);
    font-family: var(--font-secondary);
    font-weight: 400;
    letter-spacing: 0.02em;
    margin: 0;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(3rem, 6vw, 5.35rem);
    line-height: 0.9;
    white-space: nowrap;
  }

  h2 {
    font-size: clamp(2rem, 3vw, 2.6rem);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .lead {
    color: var(--color-text);
    font-size: clamp(1.35rem, 2.2vw, 1.85rem);
    line-height: 1.3;
    margin: 1.25rem 0 0;
    max-width: 920px;
    opacity: 0.92;
  }

  .poster {
    margin-bottom: 3.75rem;
  }

  .poster img {
    display: block;
    height: auto;
    width: 100%;
  }

  .lower-grid {
    align-items: start;
    display: grid;
    gap: 3rem;
    grid-template-columns: minmax(0, 1fr) 360px;
  }

  .contest-copy p,
  .requirements li,
  table {
    color: var(--color-text);
    font-size: 1.18rem;
    line-height: 1.58;
    opacity: 0.94;
  }

  .contest-copy p {
    hyphens: auto;
    margin: 0 0 1.15rem;
    text-align: justify;
    text-align-last: left;
  }

  .contest-copy a {
    color: var(--color-text);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--color-primary);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .contest-copy a:hover {
    color: var(--color-primary);
  }

  .requirements {
    margin-top: 2.5rem;
  }

  .requirements ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .requirements li {
    border-top: 1px solid color-mix(in srgb, var(--color-text) 18%, transparent);
    padding: 0.85rem 0 0.85rem 1.65rem;
    position: relative;
  }

  .requirements li::before {
    color: var(--color-primary);
    content: "✦";
    left: 0;
    position: absolute;
  }

  .details {
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
  }

  table {
    border-collapse: collapse;
    margin-bottom: 0;
    width: 100%;
  }

  th,
  td {
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 18%, transparent);
    padding: 0.9rem 0;
    text-align: left;
    vertical-align: middle;
  }

  th {
    padding-right: 1rem;
    width: 38%;
  }

  td {
    color: var(--color-text);
  }

  .details .btn-retro {
    display: block;
    margin: 5rem auto 0;
    width: max-content;
  }

  .submission-disabled {
    cursor: not-allowed;
    opacity: 0.68;
    pointer-events: none;
  }

  .prize-marquee {
    border: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: minmax(240px, 0.95fr) repeat(3, minmax(0, 1fr));
    margin: 3.75rem auto 0;
    overflow: hidden;
  }

  .total,
  .marquee-prize {
    min-height: 8.9rem;
    padding: 1.15rem 1.35rem;
  }

  .total {
    background: var(--color-primary);
    color: var(--color-body);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .total > span {
    color: var(--color-body);
    display: block;
    font-family: var(--font-secondary);
    letter-spacing: 0.14em;
    margin: 0 0 0.35rem;
    text-transform: uppercase;
  }

  .total strong {
    display: block;
    font-family: var(--font-secondary);
    font-weight: 400;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .total-amount {
    display: block;
    font-size: clamp(2rem, 3vw, 2.75rem);
  }

  .total-unit {
    display: block;
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    letter-spacing: 0.18em;
    margin-top: 0.65rem;
  }

  .marquee-prize {
    align-items: center;
    border-left: 1px solid color-mix(in srgb, var(--color-text) 18%, transparent);
    display: grid;
    gap: 0.9rem;
    grid-template-areas:
      "rank cue"
      "rank amount";
    grid-template-columns: auto minmax(0, 1fr);
    position: relative;
  }

  .marquee-prize::after {
    background: linear-gradient(90deg, var(--color-primary), transparent);
    bottom: 1.05rem;
    content: "";
    height: 2px;
    left: 1.35rem;
    opacity: 0.7;
    position: absolute;
    right: 1.35rem;
  }

  .rank {
    align-items: flex-start;
    color: var(--color-primary);
    display: flex;
    font-family: var(--font-secondary);
    grid-area: rank;
    min-width: 5.35rem;
  }

  .rank-cue {
    align-self: end;
    color: var(--color-primary);
    font-family: var(--font-secondary);
    font-size: 0.76rem;
    grid-area: cue;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
  }

  .marquee-prize.first {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-primary) 28%, transparent),
      color-mix(in srgb, var(--color-primary) 7%, transparent)
    );
  }

  .marquee-prize.first .rank-number {
    font-size: clamp(4.8rem, 5.8vw, 6.4rem);
  }

  .marquee-prize.first .prize-amount {
    font-size: clamp(1.45rem, 1.8vw, 2rem);
  }

  .marquee-prize.second {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-primary) 16%, transparent),
      color-mix(in srgb, var(--color-primary) 4%, transparent)
    );
  }

  .marquee-prize.second .rank-number {
    font-size: clamp(4.35rem, 5.25vw, 5.9rem);
  }

  .marquee-prize.third {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-primary) 9%, transparent),
      color-mix(in srgb, var(--color-primary) 2%, transparent)
    );
  }

  .marquee-prize.third .rank-number {
    font-size: clamp(3.95rem, 4.75vw, 5.35rem);
  }

  .rank-number {
    font-size: clamp(4rem, 5vw, 5.7rem);
    line-height: 0.72;
  }

  .rank-suffix {
    font-size: clamp(0.8rem, 1vw, 1rem);
    letter-spacing: 0.16em;
    line-height: 1;
    margin-left: 0.12rem;
    margin-top: 0.15rem;
    text-transform: uppercase;
  }

  .marquee-prize strong {
    color: var(--color-text);
    display: flex;
    flex-direction: column;
    font-weight: 700;
    gap: 0.2rem;
    grid-area: amount;
    line-height: 1;
    min-width: 0;
    position: relative;
    z-index: 1;
  }

  .prize-amount {
    display: block;
    font-size: clamp(1.3rem, 1.55vw, 1.75rem);
  }

  .prize-unit {
    color: var(--color-text-light);
    display: block;
    font-family: var(--font-secondary);
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .title-row {
      align-items: flex-start;
      flex-direction: column;
    }

    .lower-grid,
    .prize-marquee {
      grid-template-columns: 1fr;
    }

    .marquee-prize {
      border-left: 0;
      border-top: 1px solid color-mix(in srgb, var(--color-text) 18%, transparent);
    }

    h1 {
      font-size: clamp(2.35rem, 11vw, 3.4rem);
      white-space: normal;
    }

    .lead strong {
      white-space: nowrap;
    }
  }
</style>
