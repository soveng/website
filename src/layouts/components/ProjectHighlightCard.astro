---
import type { ProjectHighlight } from '@/data/projectHighlights';

interface Props {
  highlight: ProjectHighlight;
  index: number;
}

const { highlight, index } = Astro.props;
const variant = highlight.variant ?? 'standard';
const imageAlt = highlight.imageAlt ?? (highlight.image ? `${highlight.title} wireframe illustration` : undefined);
---

<article
  class:list={['project-card', `project-card--${variant}`]}
  style={`--i: ${index}`}
>
  <div class="project-card-media">
    {highlight.image ? (
      <>
        <img
          src={highlight.image}
          alt={imageAlt}
          class="project-card-wireframe"
          loading="lazy"
          decoding="async"
        />
        <div class="project-card-media-overlay" aria-hidden="true"></div>
      </>
    ) : (
      <div class="project-card-brand-logo">
        {highlight.logo && (
          <img src={highlight.logo} alt={`${highlight.title} logo`} loading="lazy" decoding="async" />
        )}
      </div>
    )}

    <span class="project-card-eyebrow">{highlight.eyebrow}</span>

    {highlight.logo && highlight.image && (
      <div class="project-card-logo-badge">
        <img src={highlight.logo} alt={`${highlight.title} logo`} loading="lazy" decoding="async" />
      </div>
    )}
  </div>

  <div class="project-card-body">
    <h3 class="project-card-title projects-display text-white">{highlight.title}</h3>
    <p class="projects-body mt-3 text-base leading-relaxed text-gray-300">{highlight.description}</p>

    <div class="project-card-links">
      {highlight.links.map((link, linkIndex) => {
        const isExternal = link.external ?? link.href.startsWith('http');
        const isPrimary = linkIndex === 0;

        return (
          <a
            href={link.href}
            class:list={[isPrimary ? 'btn-retro btn-retro-sm' : 'project-card-link-secondary']}
            target={isExternal ? '_blank' : undefined}
            rel={isExternal ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</article>
