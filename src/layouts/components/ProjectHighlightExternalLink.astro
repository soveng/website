---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a
  href={href}
  class="highlight-external-link"
  target="_blank"
  rel="noopener noreferrer"
  title={`Open ${label}`}
  aria-label={`Open ${label} in a new tab`}
>
  <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
</a>
