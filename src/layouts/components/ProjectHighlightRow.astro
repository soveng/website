---
import type { ProjectHighlight } from '@/data/projectHighlights';
import ProjectMark from '@/layouts/components/ProjectMark.astro';

interface Props {
  highlight: ProjectHighlight;
}

const { highlight } = Astro.props;
---

<a href={highlight.href} class="highlight-row">
  {highlight.image ? (
    <img
      class="highlight-row-thumb"
      src={highlight.image}
      alt=""
      loading="lazy"
      decoding="async"
    />
  ) : highlight.icon || highlight.logo ? (
    <ProjectMark name={highlight.title} icon={highlight.icon} logo={highlight.logo} />
  ) : null}
  <span class="highlight-row-title projects-display">{highlight.title}</span>
  <span class="highlight-row-desc projects-body">{highlight.description}</span>
  <span class="highlight-row-meta">{highlight.eyebrow}</span>
</a>
