---
import { getCohortNextPromo } from '@/data/cohortCtas';

interface Props {
  cohort: string;
}

const { cohort } = Astro.props;
const promo = getCohortNextPromo(cohort);
---

{
  promo && (
    <aside class="cohort-next-promo">
      <p class="projects-eyebrow">{promo.eyebrow}</p>
      <h2 class="projects-display projects-headline mt-3 text-3xl text-white sm:text-4xl">{promo.title}</h2>
      <p class="cohort-intro projects-body">{promo.paragraph}</p>
      <a href={promo.forward.href} class="btn-retro mt-6 inline-block">
        {promo.applyLabel}
      </a>
    </aside>
  )
}
