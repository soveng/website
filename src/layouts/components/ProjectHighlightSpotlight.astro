---
import type { ProjectHighlight } from '@/data/projectHighlights';
import ProjectExternalLink from '@/layouts/components/ProjectExternalLink.astro';

interface Props {
  highlight: ProjectHighlight;
}

const { highlight } = Astro.props;
const imageAlt = highlight.imageAlt ?? `${highlight.title} wireframe illustration`;
---

<article class="highlight-spotlight">
  {highlight.image && (
    <a href={highlight.href} class="highlight-spotlight-media-link">
      <div class="highlight-spotlight-media">
        <img src={highlight.image} alt={imageAlt} loading="lazy" decoding="async" />
      </div>
    </a>
  )}
  <div class="highlight-spotlight-body">
    <div class="highlight-spotlight-heading">
      <a href={highlight.href} class="highlight-spotlight-text-link">
        <p class="highlight-spotlight-meta">{highlight.eyebrow}</p>
        <h3 class="highlight-spotlight-title projects-display">{highlight.title}</h3>
      </a>
      {highlight.externalUrl && (
        <ProjectExternalLink href={highlight.externalUrl} label={highlight.title} />
      )}
    </div>
    <a href={highlight.href} class="highlight-spotlight-desc-link">
      <p class="highlight-spotlight-desc projects-body">{highlight.description}</p>
    </a>
  </div>
</article>
