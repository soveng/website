---
interface LinkedEntity {
  name: string;
  href: string;
}

interface Props {
  appearance: {
    url: string;
    title: string;
    source: string;
    dateLabel: string;
    durationLabel: string;
    description: string;
    alumni: LinkedEntity[];
    projects: LinkedEntity[];
  };
  variant?: 'feature' | 'archive';
}

const { appearance, variant = 'feature' } = Astro.props;
const hasAlumni = appearance.alumni.length > 0;
const hasProjects = appearance.projects.length > 0;
---

<p class="media-meta">
  {appearance.source} <span class="media-meta-sep">·</span> {appearance.dateLabel}
  <span class="media-meta-sep">·</span> {appearance.durationLabel}
</p>
<h3 class:list={['projects-display', variant === 'feature' ? 'media-feature-title' : 'media-archive-title']}>
  <a href={appearance.url} target="_blank" rel="noopener noreferrer" class="media-title-link">{appearance.title}</a>
</h3>
<p class:list={['projects-body', variant === 'feature' ? 'media-feature-desc' : 'media-archive-desc']}>
  {appearance.description}
</p>
{
  (hasAlumni || hasProjects) && (
    <p class="projects-body media-people">
      {hasAlumni && (
        <>
          With{' '}
          {appearance.alumni.map((profile, index) => (
            <>{index > 0 && ', '}<a href={profile.href} target="_blank" rel="noopener noreferrer">{profile.name}</a></>
          ))}
        </>
      )}
      {hasAlumni && hasProjects && <span class="media-meta-sep"> · </span>}
      {appearance.projects.map((project, index) => (
        <>{index > 0 && ', '}<a href={project.href}>{project.name}</a></>
      ))}
    </p>
  )
}
