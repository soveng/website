---
import type { ProjectHighlight } from "@/data/projectHighlights";

interface Props {
  highlights: ProjectHighlight[];
}

const { highlights } = Astro.props;
---

<div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
  {highlights.map((highlight: ProjectHighlight) => (
    <article class="group flex h-full flex-col overflow-hidden border border-primary/35 bg-[#050505] transition-colors duration-200 hover:border-primary">
      <div class="relative aspect-[4/3] overflow-hidden border-b border-primary/20 bg-black">
        {highlight.image ? (
          <>
            <img
              src={highlight.image}
              alt=""
              class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.02]"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
          </>
        ) : (
          <div class="flex h-full items-center justify-center bg-[radial-gradient(circle_at_top,_rgba(237,50,56,0.18),_transparent_55%),linear-gradient(180deg,#090909_0%,#020202_100%)] px-6">
            {highlight.logo && (
              <img
                src={highlight.logo}
                alt={`${highlight.title} logo`}
                class="h-28 w-28 object-contain"
              />
            )}
          </div>
        )}

        <div class="absolute left-4 top-4">
          <span class="inline-flex border border-white/15 bg-black/75 px-2 py-1 text-[11px] font-medium uppercase tracking-[0.22em] text-white/80 backdrop-blur-sm">
            {highlight.eyebrow}
          </span>
        </div>

        {highlight.logo && highlight.image && (
          <div class="absolute bottom-4 right-4 flex h-14 w-14 items-center justify-center border border-white/15 bg-black/75 p-2 backdrop-blur-sm">
            <img
              src={highlight.logo}
              alt={`${highlight.title} logo`}
              class="h-full w-full object-contain"
            />
          </div>
        )}
      </div>

      <div class="flex flex-1 flex-col p-5">
        <h2
          class="text-3xl text-white"
          style="font-family: 'IM Fell Double Pica', Times, serif;"
        >
          {highlight.title}
        </h2>
        <p class="mt-3 text-base leading-relaxed text-gray-300">
          {highlight.description}
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          {highlight.links.map((link) => {
            const isExternal = link.external ?? link.href.startsWith("http");

            return (
              <a
                href={link.href}
                class="inline-flex items-center border border-primary/45 px-3 py-2 text-sm text-white transition-colors hover:border-primary hover:text-primary"
                target={isExternal ? "_blank" : undefined}
                rel={isExternal ? "noopener noreferrer" : undefined}
              >
                {link.label}
              </a>
            );
          })}
        </div>
      </div>
    </article>
  ))}
</div>
