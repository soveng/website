---
import type { ProjectHighlight } from '@/data/projectHighlights';
import ProjectHighlightCard from '@/layouts/components/ProjectHighlightCard.astro';

interface Props {
  highlights: ProjectHighlight[];
}

const { highlights } = Astro.props;
---

<div class="project-highlights-grid">
  {highlights.map((highlight: ProjectHighlight, index: number) => (
    <ProjectHighlightCard highlight={highlight} index={index} />
  ))}
</div>
