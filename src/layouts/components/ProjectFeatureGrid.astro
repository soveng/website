---
import type { ProjectHighlight } from '@/data/projectHighlights';
import ProjectHighlightRow from '@/layouts/components/ProjectHighlightRow.astro';
import ProjectHighlightSpotlight from '@/layouts/components/ProjectHighlightSpotlight.astro';

interface Props {
  highlights: ProjectHighlight[];
}

const { highlights } = Astro.props;
const spotlight = highlights.filter((h) => h.variant === 'featured');
const rows = highlights.filter((h) => h.variant !== 'featured' && h.variant !== 'cta');
---

<div class="project-highlights">
  {spotlight.length > 0 && (
    <div class="highlight-spotlight-grid">
      {spotlight.map((highlight: ProjectHighlight) => (
        <ProjectHighlightSpotlight highlight={highlight} />
      ))}
    </div>
  )}

  {rows.length > 0 && (
    <div class="highlight-row-list">
      {rows.map((highlight: ProjectHighlight) => (
        <ProjectHighlightRow highlight={highlight} />
      ))}
    </div>
  )}
</div>
