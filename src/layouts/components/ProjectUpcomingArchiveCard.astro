---
interface Props {
  cohort: string;
  subtitle: string;
  preview: string;
  meta: string;
  href: string;
}

const { cohort, subtitle, preview, meta, href } = Astro.props;
---

<a
  href={href}
  class="project-archive-card group"
  aria-label={`Apply for ${cohort}`}
>
  <p class="project-archive-card-meta">{meta}</p>
  <div>
    <h3 class="project-archive-card-title projects-display text-white">{cohort}</h3>
    <p class="projects-body project-archive-card-preview mt-1">
      {subtitle}. {preview}
    </p>
  </div>
  <span class="project-archive-card-arrow" aria-hidden="true">Apply →</span>
</a>
