---
import { getCohortCta } from '@/data/cohortCtas';

interface Props {
  cohort: string;
}

const { cohort } = Astro.props;
const cta = getCohortCta(cohort);
---

{
  cta && (
    <aside class="cohort-upcoming-cta">
      <p class="projects-eyebrow">{cta.eyebrow}</p>
      <h2 class="projects-display projects-headline mt-3 text-4xl text-white">{cta.title}</h2>
      <p class="projects-body mt-3 max-w-2xl text-lg leading-relaxed text-gray-300">{cta.description}</p>
      <a href={cta.href} class="btn-retro mt-6 inline-block">
        {cta.label}
      </a>
    </aside>
  )
}
