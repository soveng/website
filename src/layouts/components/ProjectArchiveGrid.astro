---
import type { CohortSummary } from "@/lib/showcase";

interface Props {
  summaries: CohortSummary[];
}

const { summaries } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
  {summaries.map((summary: CohortSummary) => {
    const names = summary.highlightProjects.length > 0
      ? summary.highlightProjects.slice(0, 3)
      : summary.sampleProjects;

    return (
      <a
        href={`/projects/${summary.cohort}`}
        class="group flex h-full flex-col border border-white/15 bg-[#050505] p-5 text-white transition-colors duration-200 hover:border-primary"
      >
        <div class="text-xs uppercase tracking-[0.22em] text-white/55">
          {summary.count} {summary.count === 1 ? "project" : "projects"}
        </div>
        <h3
          class="mt-3 text-3xl text-white"
          style="font-family: 'IM Fell Double Pica', Times, serif;"
        >
          {summary.cohort}
        </h3>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-gray-300">
          {names.join(", ")}
        </p>
        <span class="mt-5 inline-flex items-center text-sm text-primary transition-colors group-hover:text-white">
          View archive
        </span>
      </a>
    );
  })}
</div>
