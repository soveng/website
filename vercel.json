{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "installCommand": "bun install",
  "headers": [
    {
      "source": "/chapters/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json+chapters"
        }
      ]
    }
  ]
}
